# ============================================================
# YOUR PLACES — FRONTEND .env.example
# ============================================================
# Copy this file to .env and adjust values as needed:
#   cp .env.example .env
#
# NOTE: All VITE_ variables are baked into the JS bundle at build time.
#       Never store secrets in frontend environment variables.


# ------------------------------------------------------------
# Backend API
# ------------------------------------------------------------
# Base URL for the backend API (used by Axios / fetch in the app)
VITE_API_BASE_URL=http://localhost:5001

# ------------------------------------------------------------
# External APIs
# ------------------------------------------------------------
# Google Maps API key (restrict to your domain in Google Cloud Console)
VITE_GOOGLE_API_KEY=your_google_api_key_here

# ------------------------------------------------------------
# Image Manager (Openinary)
# ------------------------------------------------------------
VITE_OPENINARY_URL=http://localhost:3000
